+
+${metaExport(meta)}
+export const HISTORY_FROM = ${h.fromYear};
+export const HISTORY_TO = ${h.toYear}; // exclusive; the bake year
+
+const P = '${codec.prefixesPacked}';
+const H = '${classes.join('|')}';
+
+export const historyClasses = decodeHistory(P, H, HISTORY_FROM);
+`;
+}

+      const y = (e.fromYear - h.fromYear).toString(36);
+
+      if (e.kind === 0) return `${y}s${e.offs[0]}`;
+
+      if (e.kind === 1) {
+        const rs = e.rules!.map((r) => `${r.month},${r.nth},${r.dow},${r.atMin},${r.to}`).join(',');
+        return `${y}r${e.offs[0]},${e.offs[1]},${rs}`;
+      }
+
+      return `${y}w${e.steps!.map((s, i) => `${s}:${e.offs[i]}`).join(',')}`;
+    });
+
+    return `${zs}~${eras.join(';')}`;
+  });
+

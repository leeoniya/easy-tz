+
+// history classes: '<zones>~<era>;<era>;...' per class, '|' between classes.
+// era: '<fromYear-fromYearBase, base36><s|r|w><payload>':
+//   s<off>                        static span
+//   r<offA>,<offB>,<m,n,d,at,to>x2  rule span (two nth-weekday rules)
+//   w<step>:<off>(,<step>:<off>)*   raw single year, 15-min steps
+export function decodeHistory(prefixesPacked: string, historyPacked: string, fromYearBase: number): HistoryClass[] {
+  if (historyPacked === '') return [];
+
+  const prefixes = prefixesPacked.split('|');
+
+  return historyPacked.split('|').map((c) => {
+    const cut = c.indexOf('~');
+    const zones = decodeZones(prefixes, c.slice(0, cut));
+
+    const eras: HistoryEra[] = c.slice(cut + 1).split(';').map((e) => {
+      const fromYear = fromYearBase + parseInt(e[0]!, 36);
+      const type = e[1]!;
+      const payload = e.slice(2);
+
+      if (type === 's') {
+        return { fromYear, kind: 0, offs: [+payload], rules: null, steps: null };
+      }
+
+      if (type === 'r') {
+        const n = payload.split(',').map(Number);
+        const rule = (i: number): Rule =>
+          ({ month: n[i]!, nth: n[i + 1]!, dow: n[i + 2]!, atMin: n[i + 3]!, to: n[i + 4]! as 0 | 1 });
+
+        return { fromYear, kind: 1, offs: [n[0]!, n[1]!], rules: [rule(2), rule(7)], steps: null };
+      }
+
+      const steps: number[] = [];
+      const offs: number[] = [];
+
+      for (const seg of payload.split(',')) {
+        const [step, off] = seg.split(':');
+        steps.push(+step!);
+        offs.push(+off!);
+      }
+
+      return { fromYear, kind: 2, offs, rules: null, steps };
+    });
+
+    return { zones, eras };
+  });
+}

{
  "name": "@leeoniya/easy-tz",
  "version": "0.1.1",
  "description": "Fast, tiny getTimeZonesAt(): DST-aware abbreviations and UTC offsets for every IANA zone at a timestamp",
  "license": "MIT",
  "repository": "github:leeoniya/easy-tz",
  "keywords": [
    "tz",
    "timezone",
    "time zone",
    "timezone picker",
    "IANA",
    "tzdata",
    "DST",
    "abbreviation",
    "UTC offset",
    "Intl"
  ],
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/07-baked-rules/index.d.ts",
      "default": "./dist/07-baked-rules/index.mjs"
    },
    "./10-audited-rules": {
      "types": "./dist/10-audited-rules/index.d.ts",
      "default": "./dist/10-audited-rules/index.mjs"
    },
    "./07-baked-rules": {
      "types": "./dist/07-baked-rules/index.d.ts",
      "default": "./dist/07-baked-rules/index.mjs"
    },
    "./08-verified-sharing": {
      "types": "./dist/08-verified-sharing/index.d.ts",
      "default": "./dist/08-verified-sharing/index.mjs"
    },
    "./04-live-intl": {
      "types": "./dist/04-live-intl/index.d.ts",
      "default": "./dist/04-live-intl/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "tsc -p tsconfig.json",
    "build": "bun tools/build-dist.ts",
    "test": "bun test && bun tools/test-chrome.ts",
    "test:tz": "TZ=UTC bun test && TZ=America/Chicago bun test && TZ=Pacific/Kiritimati bun test",
    "bench": "bun tools/bench-all.ts",
    "size": "bun bench/size.ts",
    "mem": "bun bench/mem.ts",
    "gen": "bun tools/gen-all.ts",
    "tables": "bun tools/use-tables.ts",
    "browsers:install": "bunx browsers install chrome-headless-shell@stable --path .browsers",
    "audit": "bun tools/audit-abbrs.ts",
    "sweep": "bun tools/sweep-validity.ts",
    "prepublishOnly": "bun run check && bun run build"
  },
  "devDependencies": {
    "@puppeteer/browsers": "3.0.6",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "leeoniya-timezones": "github:leeoniya/timezones#2cd74a8",
    "moment-timezone": "0.6.3",
    "puppeteer-core": "25.3.0",
    "timezone": "1.0.23",
    "timezone-support": "3.1.0",
    "timezonecomplete": "5.15.1",
    "typescript": "7.0.2"
  }
}
